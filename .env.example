# =============================================================================
# WID Platform — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# =============================================================================

# ── Infrastructure Secrets ──
# These have safe local-dev defaults in docker-compose. Override for production.
# POSTGRES_PASSWORD=            # Default: wip_password (local dev only)
# JWT_SECRET=                   # Default: dev-secret-change-in-production
# VAULT_DEV_ROOT_TOKEN=         # Default: root-token (dev mode only)

# ── GCP Central Control Plane URL (required for spoke mode) ──
CENTRAL_URL=

# ── AWS (enables 5 AWS scanners) ──
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1

# ── GCP (auto-detected on Cloud Run; set manually for local) ──
# GCP_PROJECT_ID=
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ── Azure (enables Azure + Entra ID scanners) ──
# AZURE_SUBSCRIPTION_ID=
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=

# ── GitHub (enables CI/CD scanner) ──
# GITHUB_TOKEN=
# GITHUB_ORG=
