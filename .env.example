# =============================================================================
# WID Platform — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# =============================================================================

# ── Database (local fullstack dev only) ──
DATABASE_URL=postgresql://wip_user:wip_password@localhost:5432/workload_identity

# ── Vault (local fullstack dev only) ──
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=root-token

# ── OPA (local fullstack dev only) ──
OPA_URL=http://localhost:8181

# ── GCP Central Control Plane URL (spoke mode) ──
CENTRAL_URL=http://your-lb-ip-here

# ── AWS Credentials (enables AWS scanners in discovery-service) ──
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_DEFAULT_REGION=us-east-1

# ── GCP Credentials (auto-detected on Cloud Run, manual for local) ──
# GCP_PROJECT_ID=your-gcp-project-id
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ── Azure Credentials (enables Azure scanners) ──
# AZURE_SUBSCRIPTION_ID=your-subscription-id
# AZURE_TENANT_ID=your-tenant-id
# AZURE_CLIENT_ID=your-client-id
# AZURE_CLIENT_SECRET=your-client-secret

# ── GitHub / CI-CD Scanner (optional) ──
# GITHUB_TOKEN=your-github-personal-access-token
# GITHUB_ORG=your-github-org

# ── Webhook Secret (optional) ──
# WEBHOOK_SECRET=change-this-to-random-secret

# ── Policy Sync (defaults are fine for most setups) ──
# SYNC_METHOD=hybrid
# POLL_INTERVAL=30000
